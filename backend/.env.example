PORT=3017
NODE_ENV=development
TRACECRAFT_CORS_ORIGINS=http://localhost:3016,http://localhost:3018

# 地图服务提供商（按优先级）
MAP_PROVIDER_DEFAULT=amap
MAP_PROVIDER_LIST=amap,google,baidu
MAP_LOCALES=zh-CN,en-US
MAP_LOCALE_FALLBACK=zh-CN
MAP_LOCALE_LABELS={"zh-CN":"中文","en-US":"English"}

# 仅示例：服务端环境变量配置，前端不应读取明文 key
AMAP_KEY=your-amap-api-key-here
GOOGLE_MAPS_KEY=
BAIDU_MAP_KEY=

# Storage strategy: postgres
TRACECRAFT_STORAGE=postgres
PG_POOL_MAX=8
PG_POOL_IDLE_TIMEOUT_MS=30000

# PostgreSQL 推荐连接（任选其一）
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/tracecraft

# 本地开发登录必须显式开启；正式环境不要开启。
TRACECRAFT_ALLOW_DEV_AUTH=1
TRACECRAFT_DEV_SMS_CODE=8888
# SMS Provider: aliyun | tencent | webhook（未设置则需开启 dev 模式）
TRACECRAFT_SMS_PROVIDER=webhook
TRACECRAFT_SMS_WEBHOOK_URL=
TRACECRAFT_SMS_WEBHOOK_SECRET=
TRACECRAFT_SMS_TEMPLATE=tracecraft_login

# 阿里云短信（TRACECRAFT_SMS_PROVIDER=aliyun 时必需）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION=cn-hangzhou

# 腾讯云短信（TRACECRAFT_SMS_PROVIDER=tencent 时必需）
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
TRACECRAFT_SMS_CODE_SECRET=replace-with-long-random-sms-code-secret
TRACECRAFT_SMS_CODE_TTL_SECONDS=300
TRACECRAFT_SMS_RESEND_INTERVAL_SECONDS=60
TRACECRAFT_SMS_MAX_ATTEMPTS=5
# OAuth Provider: wechat | alipay | webhook（未设置则需开启 dev 模式）
TRACECRAFT_OAUTH_PROVIDER=webhook
TRACECRAFT_OAUTH_WEBHOOK_URL=
TRACECRAFT_OAUTH_WEBHOOK_SECRET=

# 微信 OAuth（TRACECRAFT_OAUTH_PROVIDER=wechat 时必需）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 支付宝 OAuth（TRACECRAFT_OAUTH_PROVIDER=alipay 时必需）
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
TRACECRAFT_USER_TOKEN_SECRET=replace-with-long-random-user-token-secret
TRACECRAFT_USER_TOKEN_TTL_HOURS=2
TRACECRAFT_USER_REFRESH_TOKEN_SECRET=replace-with-long-random-user-refresh-token-secret
TRACECRAFT_USER_REFRESH_TOKEN_TTL_HOURS=720
TRACECRAFT_ALLOW_UNVERIFIED_ROUTES=0

# 仅兼容旧种子账号本地登录；正式环境必须关闭并写入 scrypt 密码哈希。
TRACECRAFT_ALLOW_ADMIN_PASSWORD_FALLBACK=1
TRACECRAFT_ADMIN_PASSWORD=replace-with-local-admin-password
TRACECRAFT_ADMIN_TOKEN_SECRET=replace-with-long-random-admin-token-secret
TRACECRAFT_ADMIN_TOKEN_KID=default
# Optional rotated keys, comma separated: kid1:long-secret,kid2:long-secret
TRACECRAFT_ADMIN_TOKEN_SECRETS=
TRACECRAFT_ADMIN_TOKEN_TTL_HOURS=12

# Redis（ioredis + BullMQ + rate-limit-redis 依赖）
# 不配置或连接失败时自动降级：限流回退内存、队列同步执行、缓存跳过
REDIS_URL=redis://127.0.0.1:6379
TRACECRAFT_LOCATION_EVENT_RETENTION_DAYS=90
TRACECRAFT_AUDIT_LOG_RETENTION_DAYS=180

# Asset storage: local | s3 | webhook
TRACECRAFT_ASSET_STORAGE_PROVIDER=local
TRACECRAFT_ASSET_WEBHOOK_URL=
TRACECRAFT_ASSET_WEBHOOK_SECRET=
TRACECRAFT_ASSET_PUBLIC_BASE_URL=

# S3 兼容存储（AWS S3 / 阿里云 OSS / MinIO）
# TRACECRAFT_ASSET_STORAGE_PROVIDER=s3 时必需
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
