PORT=3001
NODE_ENV=development

# 地图服务提供商（按优先级）
MAP_PROVIDER_DEFAULT=amap
MAP_PROVIDER_LIST=amap,google,baidu
MAP_LOCALES=zh-CN,en-US
MAP_LOCALE_FALLBACK=zh-CN
MAP_LOCALE_LABELS={"zh-CN":"中文","en-US":"English"}

# 仅示例：服务端环境变量配置，前端不应读取明文 key
AMAP_KEY=73bc01cfced7123b05cdcd670cc3ccc4
GOOGLE_MAPS_KEY=
BAIDU_MAP_KEY=

# Storage strategy: postgres
TRACECRAFT_STORAGE=postgres
PG_POOL_MAX=8
PG_POOL_IDLE_TIMEOUT_MS=30000

# PostgreSQL 推荐连接（任选其一）
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/tracecraft

# Redis 预留（v2 第2周后放开）
REDIS_URL=redis://127.0.0.1:6379
REDIS_SESSION_TTL_SECONDS=180
