{
  "name": "tracecraft-backend",
  "version": "0.1.0",
  "private": true,
  "description": "TraceCraft backend API service",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "migrate": "tsx src/scripts/migrate.ts",
